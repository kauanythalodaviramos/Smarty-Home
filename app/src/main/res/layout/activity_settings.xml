<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_settings"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1e2124">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_margin="24dp"
        android:background="@drawable/dialog_sensor_bg"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Profile Section -->
        <TextView
            android:id="@+id/tv_profile_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="change your perfil image"
            android:textColor="#cab2fb"
            android:textSize="14sp"
            android:textStyle="bold" />

        <FrameLayout
            android:id="@+id/btn_change_avatar"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:background="@drawable/circle_avatar_bg"
            android:padding="4dp">

            <ImageView
                android:id="@+id/iv_profile"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_launcher_background" />

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="bottom|end"
                android:background="@drawable/circle_camera_bg"
                android:padding="6dp"
                android:src="@android:drawable/ic_menu_camera" />
        </FrameLayout>

        <!-- Name Section -->
        <TextView
            android:id="@+id/tv_name_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:text="change your name"
            android:textColor="#cab2fb"
            android:textSize="14sp"
            android:textStyle="bold" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/input_background">

            <EditText
                android:id="@+id/et_new_name"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@null"
                android:hint="Full Name"
                android:inputType="textPersonName"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="#333333"
                android:textColorHint="#c0aab0" />
        </FrameLayout>

        <!-- Password Section -->
        <TextView
            android:id="@+id/tv_password_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:text="change your password"
            android:textColor="#cab2fb"
            android:textSize="14sp"
            android:textStyle="bold" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/input_background">

            <EditText
                android:id="@+id/et_new_password"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@null"
                android:hint="New Password"
                android:inputType="textPassword"
                android:paddingStart="16dp"
                android:paddingEnd="48dp"
                android:textColor="#333333"
                android:textColorHint="#c0aab0" />

            <ImageButton
                android:id="@+id/btn_toggle_new_password"
                android:layout_width="48dp"
                android:layout_height="match_parent"
                android:layout_gravity="end"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_eye_closed"
                android:tint="#cab2fb"
                android:contentDescription="Toggle visibility" />
        </FrameLayout>

        <!-- Theme Section -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <CheckBox
                android:id="@+id/cb_theme"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="#cab2fb" />

            <TextView
                android:id="@+id/tv_theme_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dark Mode"
                android:textColor="#ffffff"
                android:textSize="14sp" />

            <ImageView
                android:id="@+id/iv_theme_icon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="8dp"
                android:src="@android:drawable/ic_menu_info_details" />
        </LinearLayout>

        <!-- Action Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_discard"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:background="@drawable/btn_discard_bg"
                android:text="discard changes"
                android:textAllCaps="false"
                android:textColor="#ffffff"
                android:textSize="12sp"
                android:padding="0dp" />

            <Button
                android:id="@+id/btn_save"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/btn_primary"
                android:text="save changes"
                android:textAllCaps="false"
                android:textColor="#ffffff"
                android:textSize="12sp"
                android:padding="0dp" />
        </LinearLayout>

    </LinearLayout>

    <Button
        android:id="@+id/btn_back_to_dashboard"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="24dp"
        android:background="@drawable/btn_settings_dashboard"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:text="Back to Dashboard"
        android:textAllCaps="false"
        android:textColor="#ffffff" />

</FrameLayout>
