<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/dialog_sensor_bg"
    android:padding="20dp">

    <!-- Close X top right -->
    <Button
        android:id="@+id/btn_close_all"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="top|end"
        android:background="@drawable/btn_close_x"
        android:text="✕"
        android:textColor="#b4313d"
        android:textSize="16sp"
        android:textAllCaps="false"
        android:padding="0dp"
        android:elevation="4dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="48dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:baselineAligned="false">

        <!-- Light chart -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginEnd="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🕯 Light"
                android:textColor="#ffeaae"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <FrameLayout
                android:id="@+id/chart_all_light"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/chart_area_bg" />
        </LinearLayout>

        <!-- Temp chart -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginEnd="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔥 Temp"
                android:textColor="#e95e3f"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <FrameLayout
                android:id="@+id/chart_all_temp"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/chart_area_bg" />
        </LinearLayout>

        <!-- Hum chart -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🧪 Humidity"
                android:textColor="#338cca"
                android:textSize="14sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <FrameLayout
                android:id="@+id/chart_all_hum"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/chart_area_bg" />
        </LinearLayout>

    </LinearLayout>

</FrameLayout>
