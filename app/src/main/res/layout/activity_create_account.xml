<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1e2124">

    <!-- Outer glow / soft shadow layer -->
    <LinearLayout
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@drawable/card_shadow"
        android:orientation="vertical"
        android:elevation="12dp">

        <!-- Main card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_background"
            android:orientation="vertical"
            android:padding="28dp">

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="24dp"
                android:text="Create Account"
                android:textColor="#cab2fb"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />

            <!-- Email label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="Email"
                android:textColor="#7a6a8a"
                android:textSize="12sp" />

            <!-- Email field -->
            <EditText
                android:id="@+id/et_email"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/input_background"
                android:hint="your@email.com"
                android:inputType="textEmailAddress"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="#3a2a3a"
                android:textSize="14sp" />

            <!-- Password label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="Password"
                android:textColor="#7a6a8a"
                android:textSize="12sp" />

            <!-- Password row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="28dp"
                android:background="@drawable/input_background"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/et_password"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="••••••••"
                    android:inputType="textPassword"
                    android:paddingStart="14dp"
                    android:paddingEnd="4dp"
                    android:textColor="#3a2a3a"
                    android:textSize="14sp" />

                <ImageButton
                    android:id="@+id/btn_toggle_password"
                    android:layout_width="44dp"
                    android:layout_height="match_parent"
                    android:background="@null"
                    android:contentDescription="Toggle password visibility"
                    android:paddingEnd="10dp"
                    android:src="@drawable/ic_eye_closed"
                    android:tint="#cab2fb" />
            </LinearLayout>

            <!-- Button row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <!-- Get Back (smaller) -->
                <Button
                    android:id="@+id/btn_get_back"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/btn_secondary"
                    android:text="Get Back"
                    android:textColor="#3a4a2a"
                    android:textSize="11sp"
                    android:textAllCaps="false"
                    android:fontFamily="sans-serif-medium" />

                <!-- Create Account (main) -->
                <Button
                    android:id="@+id/btn_create_account"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1.3"
                    android:background="@drawable/btn_primary"
                    android:text="Create Account"
                    android:textColor="#ffffff"
                    android:textSize="11sp"
                    android:textAllCaps="false"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

</FrameLayout>